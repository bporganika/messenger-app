DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pulse?schema=public"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production-refresh"
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN="https://pulse.app"

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID="your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_FROM_PHONE="+1234567890"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Apple Sign-In
APPLE_BUNDLE_ID="com.pulse.messenger"

# S3 (file uploads)
S3_BUCKET="pulse-uploads"
S3_REGION="eu-central-1"
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_ENDPOINT=""
