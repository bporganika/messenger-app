{
  "name": "pulse-messenger",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "server": "npm run dev -w @pulse/server",
    "mobile": "npm run start -w @pulse/mobile",
    "shared:build": "npm run build -w @pulse/shared",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
